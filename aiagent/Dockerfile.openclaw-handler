# Dockerfile for OpenClaw Handler
# Process Manager for OpenClaw Framework
# Uses ImageVolume to access Framework's filesystem at /framework-rootfs
#
# Architecture:
# ┌─────────────────────────────────────────────────────────────────┐
# │ Handler Container (Process Manager)                             │
# │                                                                 │
# │  VolumeMounts:                                                  │
# │    /framework-rootfs -> ImageVolume (OpenClaw Framework image) │
# │    /etc/harness/<name> -> Harness ConfigMaps                    │
# │    /shared/workdir -> EmptyDir (agent workspace)                │
# │                                                                 │
# │  Starts Framework:                                              │
# │    exec.Command("/framework-rootfs/usr/local/bin/openclaw")     │
# │                                                                 │
# │  Framework processes run in same Pod's PID namespace            │
# │  Handler controls lifecycle (start/stop/monitor)               │
# └─────────────────────────────────────────────────────────────────┘
FROM golang:1.25-alpine AS builder

# Install git for cloning adk-go
RUN apk add --no-cache git

WORKDIR /workspace

# Clone adk-go from GitHub
RUN git clone https://github.com/google/adk-go /adk-go

# Copy aiagent go.mod and go.sum
COPY go.mod go.sum ./

# Modify replace directive to point to cloned adk-go
RUN sed -i 's|replace google.golang.org/adk => ../adk-go|replace google.golang.org/adk => /adk-go|' go.mod

# Download dependencies
RUN go mod download

# Copy source code
COPY api/ api/
COPY pkg/ pkg/
COPY cmd/ cmd/

# Build OpenClaw Handler binary
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -a -o openclaw-handler ./cmd/openclaw-handler

# Final stage
FROM alpine:3.18

WORKDIR /

RUN apk --no-cache add ca-certificates tzdata

COPY --from=builder /workspace/openclaw-handler /openclaw-handler

# Create directories
RUN mkdir -p /etc/agent-config /etc/harness && \
    mkdir -p /shared/workdir /shared/config

# Framework binary path via ImageVolume
# Handler mounts Framework image at /framework-rootfs
# OpenClaw CLI: /framework-rootfs/usr/local/bin/openclaw
ENV FRAMEWORK_BIN=/framework-rootfs/usr/local/bin/openclaw
ENV WORK_DIR=/shared/workdir
ENV CONFIG_DIR=/shared/config

ENTRYPOINT ["/openclaw-handler"]
CMD ["--debug"]